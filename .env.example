# Backend used by `npm run dev`.
DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# Public backend URL embedded into a production frontend build.
# Example: https://api.example.com
VITE_API_BASE_URL=

# Public backend endpoint that starts LINE Login and sets the state cookie.
VITE_LINE_LOGIN_URL=https://your-api-domain.example/api/v1/auth/line/login
COLORSEEK_LINE_CALLBACK_URL=https://your-api-domain.example/api/v1/auth/line/callback